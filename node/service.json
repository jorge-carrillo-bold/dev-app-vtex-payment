{
  "memory": 256,
  "ttl": 10,
  "timeout": 10,
  "minReplicas": 2,
  "maxReplicas": 3,
  "routes": {
    "authorize": {
      "path": "/payments",
      "public": true
    },
    "cancel": {
      "path": "/payments/:paymentId/cancellations",
      "public": true
    },
    "settle": {
      "path": "/payments/:paymentId/settlements",
      "public": true
    },
    "refund": {
      "path": "/payments/:paymentId/refunds",
      "public": true
    },
    "inbound": {
      "path": "/payments/:paymentId/inbound/hooks",
      "public": true
    }
  }
}
